OPENAI_API_KEY=sk-your-openai-key-here

# Writable data (SQLite memory, uploads). In Docker use /app/data via DATA_DIR.
DATA_DIR=./data
UPLOAD_DIR=./data/uploads

APP_HOST=0.0.0.0
APP_PORT=8000
# Docker / Railway / Cloud platforms often inject PORT instead of APP_PORT
APP_DEBUG=false

# Papers MCP — started in-process by scripts/docker-entrypoint.sh in Docker
MCP_HOST=0.0.0.0
MCP_PAPERS_PORT=8009
MCP_PAPERS_URL=http://127.0.0.1:8009/mcp

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=papermind
LANGSMITH_TRACING=false

# OpenAlex: no API key — set your email for the polite pool (10 req/sec)
OPENALEX_MAILTO=your@email.com

# Qdrant (optional — agent falls back to abstracts + in-session PDF chunks)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=30

# Semantic Scholar (optional — TLDR enrichment)
SEMANTIC_SCHOLAR_API_KEY=

# RAGAS evaluation (local only; disable in production)
EVAL_LLM_MODEL=gpt-4o-mini
EVAL_EMBEDDING_MODEL=text-embedding-3-small
EVAL_SAMPLES_PATH=evals/eval_samples.jsonl
EVAL_COLLECT_ENABLED=false

# Briefing rate limit (per client IP). Each run = many LLM calls + PDF fetches.
BRIEFING_RATE_LIMIT=5/hour
BRIEFING_RATE_LIMIT_ENABLED=true
